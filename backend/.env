# ── API Keys ──────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=CG-your-key-here
CRYPTOPANIC_TOKEN=your-token-here
NEWSAPI_KEY=your-key-here

# Fear & Greed Index is fetched automatically — no API key required (alternative.me)

# ── Path to your CSV data files (BTC.csv, ETH.csv, etc.) ─────────────────────
DATA_DIR=./data

# ── CORS — add your Vercel URL here before deploying ─────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Model tuning ──────────────────────────────────────────────────────────────
# WINDOW=60        increased from 30 — more temporal context for the LSTM
# EPOCHS=150       increased from 50 — models were underfitting
# OPTUNA_TRIALS=20 increased from 15 — better hyperparameter search coverage
WINDOW=60
EPOCHS=150
OPTUNA_TRIALS=20
RUN_OPTUNA=true
ENABLE_PROPHET=true
ENABLE_SARIMA=true
ENABLE_LSTM=true
ENABLE_TRANSFORMER=true
